# ──────────────────────────────────────────────────────────────────────────
# Anbud-monitor · Volvo Norge – miljøvariabler
# Kopier til .env.local og fyll inn verdiene.
# ──────────────────────────────────────────────────────────────────────────

# Doffin Public API v2 (Azure API Management subscription key)
# Registrer en subscription på https://dof-notices-prod-api.developer.azure-api.net/
DOFFIN_API_KEY=din_doffin_subscription_key
# Valgfritt – overstyr base-URL (standard: https://api.doffin.no/public/v2)
# DOFFIN_API_BASE_URL=https://api.doffin.no/public/v2

# Resend (e-postvarsling) – https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Mottaker(e) av varsler – komma-separert for flere
NOTIFICATION_EMAIL=innkjop@volvo-eksempel.no
# Valgfri avsender (må være verifisert domene i Resend)
# NOTIFICATION_FROM=Anbud-monitor <anbud@dittdomene.no>

# Supabase – https://supabase.com (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...din_anon_key
# Anbefalt for server-side skriving (cron-jobb). Hold hemmelig – aldri NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...din_service_role_key

# Valgfri beskyttelse av /api/notifications mot uautorisert trigging.
# Settes også som header «Authorization: Bearer <secret>» i cron-tjenesten.
CRON_SECRET=et_langt_tilfeldig_hemmelig_token

# Offentlig URL til appen (brukes i invitasjons- og passordlenker)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Første administrator ved bootstrap (valgfri – standard anbud@biloversikt.com)
# INITIAL_ADMIN_EMAIL=anbud@biloversikt.com
